{
  "name": "skls",
  "version": "0.1.0",
  "description": "Agent skills manager: Centralized maintenance, on-demand installation, and automatic synchronization.",
  "license": "MIT",
  "author": "xavi",
  "type": "module",
  "bin": {
    "skls": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm type-check && pnpm test"
  },
  "keywords": [
    "agent",
    "skills",
    "cli",
    "automation",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xaviw/skills-manager.git"
  },
  "bugs": {
    "url": "https://github.com/Xaviw/skills-manager/issues"
  },
  "homepage": "https://github.com/Xaviw/skills-manager#readme",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.31.0",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}